# Copy this file to .env and fill in real values. .env is gitignored.

# Deployer key -- becomes the contract owner. Must hold Arc Testnet USDC for gas.
PRIVATE_KEY=0x...

# Arc Testnet USDC ERC-20 address (confirmed in LuckySplit_doc.md section 13)
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Platform operator wallet -- drives commit/reveal/distribute automatically.
# Can be the same address as the deployer for now; separate it later for key hygiene.
OPERATOR_ADDRESS=0x...
